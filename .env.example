# ---- Database ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=carbon
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/carbon

# ---- Auth / RBAC ----
JWT_SECRET=change-me-in-production
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=changeme

# ---- AI research layer ----
# Two ways to authenticate the live engine (leave both blank for seeded-snapshot mode):
#
#  1) SUBSCRIPTION (no API key, no billing) — runs on your Claude Max/Pro plan.
#     On your host (where Claude Code is logged in) run:  claude setup-token
#     Copy the printed token (sk-ant-oat01-...) here:
CLAUDE_CODE_OAUTH_TOKEN=
#
#  2) API KEY — from console.anthropic.com (pay-as-you-go):
ANTHROPIC_API_KEY=
#
# auto = prefer API key if set, else use the subscription token. Force with: api_key | subscription
RESEARCH_AUTH_MODE=auto
# Tip: on the subscription plan, set a lighter model to conserve your rate limits, e.g. claude-sonnet-5
RESEARCH_MODEL=claude-opus-4-8
# web search provider used by the research engine: anthropic | tavily | serper | none
WEB_SEARCH_PROVIDER=anthropic
TAVILY_API_KEY=
SERPER_API_KEY=

# ---- ETL ----
# Seeding uses the pre-extracted CSV by default. Drop the full workbook here for a full ingest.
EXCEL_PATH=/data/Voluntary-Registry-Offsets-Database.xlsx
SEED_CSV_PATH=/data/seed/projects.csv
SEED_RESEARCH_PATH=/data/seed/malawi_ar_research.json
